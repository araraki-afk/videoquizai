FROM python:3.11-slim

WORKDIR /backend

RUN apt-get update && apt-get install -y --no-install-recommends \
    build-essential \
    gcc \
    libpq-dev \
    ffmpeg \
    git \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .

# Шаг 1 — тяжёлые ML пакеты отдельно, без проверки зависимостей друг с другом
RUN pip install --upgrade pip setuptools wheel

RUN pip install --no-cache-dir torch==2.3.0 --index-url https://download.pytorch.org/whl/cpu

RUN pip install --no-cache-dir transformers==4.36.2 spacy==3.7.4 sentencepiece==0.2.0

# Шаг 2 — всё остальное
RUN pip install --no-cache-dir \
    fastapi==0.111.0 \
    uvicorn[standard]==0.29.0 \
    sqlalchemy==2.0.30 \
    alembic==1.13.1 \
    psycopg2-binary==2.9.9 \
    python-jose[cryptography]==3.3.0 \
    passlib[bcrypt]==1.7.4 \
    python-multipart==0.0.9 \
    pydantic==2.7.1 \
    pydantic-settings==2.2.1 \
    email-validator==2.1.1 \
    celery==5.4.0 \
    redis==5.0.4 \
    yt-dlp==2024.5.27 \
    pydub==0.25.1 \
    httpx==0.27.0 \
    aiohttp==3.9.5 \
    python-dotenv==1.0.1 \
    aiofiles==23.2.1 \
    Pillow==10.3.0

COPY . .

RUN mkdir -p /backend/media/uploads /backend/media/audio

EXPOSE 8000

CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]